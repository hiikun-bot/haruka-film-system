# ==================== サーバー ====================
PORT=3000
SESSION_SECRET=your-random-secret-string
# 通知メッセージ内のクリエイティブURL生成にも使用される（必須）
APP_URL=https://your-app.railway.app

# ==================== ワークスペース設定 ====================
# あなたのチーム情報に書き換えてください
WORKSPACE_NUMBER=1
WORKSPACE_NAME=YOUR TEAM NAME
WORKSPACE_SLUG=your-team-name
WORKSPACE_OWNER_EMAIL=owner@example.com
PRIMARY_COLOR=#3ECFCA

# ==================== Supabase ====================
# https://supabase.com で新規プロジェクトを作成して取得
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase 障害時にハングしないための保険（utils/supabase-fetch.js）
# - REQUEST_TIMEOUT_MS: 1リクエストあたりの上限時間（デフォルト 8000ms）
# - CB_FAILURE_THRESHOLD: 連続失敗がこの回数を超えるとサーキットを open（デフォルト 5）
# - CB_OPEN_MS: open 中は即時 reject、この時間経過後に half-open で1回だけ試す（デフォルト 30000ms）
# SUPABASE_REQUEST_TIMEOUT_MS=8000
# SUPABASE_CB_FAILURE_THRESHOLD=5
# SUPABASE_CB_OPEN_MS=30000

# Supabase 障害時の Slack 通知 (utils/maintenance-notifier.js)。
# サーキットブレーカーが open になった瞬間と closed に戻った瞬間に1回ずつ投稿する。
# 未設定の場合は ERROR_REPORT_SLACK_CHANNEL_URL が使われる。
# MAINTENANCE_SLACK_CHANNEL_URL=https://app.slack.com/client/Txxxx/Cxxxx

# ==================== Supabase Postgres 直接接続（自動スキーマ同期用） ====================
# Postgres 直接接続用（migrate.js が起動時に supabase_schema.sql を自動適用するために必須）
# Supabase ダッシュボード → Project Settings → Database → Connection string (URI) からコピー
# 未設定だと自動マイグレーションが走らず、新カラム/FKが本番に反映されない
#   - Transaction pooler または Session pooler の URL を推奨
#   - パスワードはそのまま埋め込む（Railway環境変数として保管。GitHubに含めない）
# 例: postgres://postgres.xxxxxxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# 自動同期を停止したい場合に false を指定（デフォルトは有効）
# SCHEMA_AUTO_SYNC=false

# ==================== IPベース自動ログイン（任意） ====================
# 自宅・事務所のグローバルIPから自動的に指定ユーザーでログイン
# IPは https://www.cman.jp/network/support/go_access.cgi 等で確認
# 複数指定する場合はカンマ区切り
AUTO_LOGIN_IPS=
AUTO_LOGIN_EMAIL=

# ==================== Google Drive ====================
# Google Cloud Console でサービスアカウントを作成してJSONキーを取得
# JSONを1行に圧縮して貼り付け
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id

# ==================== 素材広場 / 動画整理ツール（test / experimental） ====================
# Vertex AI Gemini を使った動画ファイル名・フォルダ自動振り分けの test 実装。
# 従量課金リスクがあるため、本番ロールアウト前に必ず以下の安全装置を確認すること。
#
# 前提作業（GCP コンソールでユーザー手動）:
#   1. GOOGLE_CLOUD_PROJECT の GCP プロジェクトで「Vertex AI API」を有効化
#   2. GOOGLE_SERVICE_ACCOUNT_KEY の SA に「Vertex AI User」ロールを付与
#   3. (任意) 課金アラート / 月次予算上限を GCP Billing で設定
#
# 機能フラグ
ENABLE_VIDEO_ORGANIZATION_TEST=false

# Vertex AI
GOOGLE_CLOUD_PROJECT=haruka-film-system
GOOGLE_CLOUD_LOCATION=asia-northeast1
# モデル名は GCP の Vertex AI ドキュメントで最新の利用可能 ID に合わせること。
# 例: gemini-1.5-pro / gemini-2.0-flash 等。存在しない ID を指定すると 404 で失敗する。
GEMINI_MODEL=gemini-1.5-pro

# 安全装置（必ず DRY_RUN=true で開始すること。本番リネームは Stage 2 で別 PR）
# 長尺動画は Vertex AI Gemini の課金が跳ねるため、複数層で防御:
#   1. フロント側: ファイル選択時に動画長を測って事前ブロック
#   2. multer:    fileSize 上限超過は 413 で拒否（アップロードすら受けない）
#   3. サーバ側:  Drive アップロード直後に duration 超過なら Drive から自動削除
#   4. analyze:   再度 MAX_DURATION_SECONDS で弾く（最終防壁）
DRY_RUN=true
STOP_ALL=false
MAX_UPLOAD_SIZE_MB=25
MAX_UPLOAD_DURATION_SECONDS=30
MAX_DURATION_SECONDS=30
MAX_RETRY_COUNT=3
DAILY_ANALYSIS_LIMIT=5

# 完全自動リネーム — AI が needs_human_review=true（要確認）と判定した素材も
# 「確認待ち (awaiting_review)」で止めず、そのまま自動リネーム＋振り分けまで進める。
# 既定 false（要確認は人がクリックして適用）。確認なしで完全自動にしたい場合のみ true。
# 注意: 自信の低い AI 提案名でもそのまま Drive 上のファイル名に適用される。
AUTO_APPLY_SKIP_REVIEW=false

# アップロード（D&D）先 Drive フォルダ — 素材広場アップロード専用フォルダの fileId
# 未設定の場合は GOOGLE_DRIVE_ROOT_FOLDER_ID にフォールバックする
VIDEO_ORG_UPLOAD_FOLDER_ID=

# ==================== 大容量 D&D（Resumable Upload, >=500MB） ====================
# 500MB を超える素材を、ブラウザ→Drive 直送でアップロードする経路の有効化フラグ。
# 既定は無効（false）。本番初期は OFF のままにし、検証後に true に切替える。
# false のとき: 500MB 超のファイルはフロントで明示エラーで止まる（既存 /upload には倒さない）。
ENABLE_RESUMABLE_UPLOAD=false

# 上記を true にする場合に必要な Google OAuth クライアント情報。
# 取得手順は docs/oauth-setup-resumable-upload.md を参照。
# OAuth 同意画面の User Type は **Internal**（株式会社HARUKAFILMのWorkspace内のみ）に設定する。
# スコープは drive.file のみ（非機密スコープなので審査・検証不要）。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://haruka-film-system-production.up.railway.app/oauth/google/callback
# 任意。スペース/カンマ区切り。デフォルトは drive.file のみ
# GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive.file
