# ==================== サーバー ====================
PORT=3000
SESSION_SECRET=your-random-secret-string
APP_URL=https://your-app.railway.app

# ==================== ワークスペース設定 ====================
# あなたのチーム情報に書き換えてください
WORKSPACE_NUMBER=1
WORKSPACE_NAME=YOUR TEAM NAME
WORKSPACE_SLUG=your-team-name
WORKSPACE_OWNER_EMAIL=owner@example.com
PRIMARY_COLOR=#3ECFCA

# ==================== Supabase ====================
# https://supabase.com で新規プロジェクトを作成して取得
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==================== Supabase Postgres 直接接続（自動スキーマ同期用） ====================
# 設定すると、アプリ起動時に supabase_schema.sql が自動で適用されます
# Supabase ダッシュボード → Project Settings → Database → Connection string
#   - Transaction pooler または Session pooler の URL を推奨
#   - パスワードはそのまま埋め込む（Railway環境変数として保管。GitHubに含めない）
# 例: postgres://postgres.xxxxxxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# 自動同期を停止したい場合に false を指定（デフォルトは有効）
# SCHEMA_AUTO_SYNC=false

# ==================== IPベース自動ログイン（任意） ====================
# 自宅・事務所のグローバルIPから自動的に指定ユーザーでログイン
# IPは https://www.cman.jp/network/support/go_access.cgi 等で確認
# 複数指定する場合はカンマ区切り
AUTO_LOGIN_IPS=
AUTO_LOGIN_EMAIL=

# ==================== Google Drive ====================
# Google Cloud Console でサービスアカウントを作成してJSONキーを取得
# JSONを1行に圧縮して貼り付け
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id

# ==================== ChatWork ====================
# ChatWork API トークン（Bot 専用アカウントを推奨）
# https://www.chatwork.com → 右上アイコン → サービス連携 → API Token
# 未設定の場合は通知がスキップされる（エラーにはならない）
CHATWORK_API_TOKEN=
