# 環境変数（絶対にコミットしない）
.env
.env.local
.env.production

# 依存パッケージ
node_modules/

# SQLiteデータベース（本番はRailway Volumeで管理）
db/*.db
db/*.db-shm
db/*.db-wal
data/*.db
data/*.db-shm
data/*.db-wal

# アップロード一時ファイル
tmp/

# macOS
.DS_Store

# ログ
*.log
npm-debug.log*

# PR で merge 待ちの migration SQL を一時的に置く場所（Supabase に手動適用するため）
# README.md は git 管理する（運用ルール記載）
pending-migrations/*
!pending-migrations/README.md
